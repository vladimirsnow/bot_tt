BOT_TOKEN=1234567890:YOUR_TELEGRAM_BOT_TOKEN
# true = бот запускается при старте ПК, false = не запускать автоматически
AUTO_START=false
# Max downloadable file size in megabytes (for video/photo)
MAX_FILE_MB=1024
# Параллельная загрузка фото из одного поста (больше = быстрее)
IMAGE_DOWNLOAD_CONCURRENCY=1000
# Параллельная обработка нескольких ссылок в одном сообщении
LINK_PROCESS_CONCURRENCY=100
# Optional: path to cookies file for yt-dlp (helps with some Instagram reels)
# YT_DLP_COOKIE_FILE=/full/path/to/cookies.txt
